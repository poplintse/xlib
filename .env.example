# Copy to .env at the repository root. Values below are placeholders only.
NODE_ENV=production
HOST=0.0.0.0
PORT=8080
DATABASE_URL=postgresql://xlib_api:replace-api-password@postgres:5432/xlib_sync
DATABASE_SSL=false
DB_POOL_MAX=10
TOKEN_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
ENFORCE_HTTPS=true
TRUST_PROXY=true
LOG_LEVEL=info
METRICS_TOKEN=replace-with-a-long-random-secret
SYNC_DOMAIN=sync.example.com
POSTGRES_DB=xlib_sync
POSTGRES_USER=xlib_owner
POSTGRES_PASSWORD=replace-owner-password
XLIB_DB_USER=xlib_api
XLIB_DB_PASSWORD=replace-api-password
